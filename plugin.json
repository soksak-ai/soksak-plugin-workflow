{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-workflow",
  "name": "Workflow",
  "version": "0.0.1",
  "description": "드래프트 파이프라인 — 아이디어를 LLM 저작 워크플로로 칸반 노드 DAG 에 발행하고, 코어 스케줄러 reconcile 로 실행·추적한다. item=exec-one 검증(badge o/x/f), task=exec-stage(generate/hunt/classify/audit 실행·자식 발행), blockedBy 의존.",
  "entry": "main.js",
  "permissions": [
    "process",
    "commands",
    "schedule",
    "secrets"
  ],
  "dependencies": {
    "soksak-plugin-kanban": "^0.1.0"
  },
  "contributes": {
    "commands": [
      {
        "name": "run",
        "title": {
          "ko": "워크플로를 발행합니다",
          "en": "Publishes the workflow"
        }
      },
      {
        "name": "ping",
        "title": {
          "ko": "프로바이더 상태를 점검합니다",
          "en": "Probes the provider"
        }
      },
      {
        "name": "reconcile",
        "title": {
          "ko": "준비된 워크플로 노드를 실행합니다",
          "en": "Runs ready workflow nodes"
        }
      },
      {
        "name": "research",
        "title": {
          "ko": "조사 워크플로를 발행합니다",
          "en": "Publishes the research workflow"
        }
      },
      {
        "name": "issuerize",
        "title": {
          "ko": "계획을 개발 이슈로 승격합니다",
          "en": "Promotes plans to issues"
        }
      },
      {
        "name": "next",
        "title": "CLI 실행자 pull — ready 검증 노드의 실행 패키지 발급(lease)"
      },
      {
        "name": "submit",
        "title": "CLI 실행자 제출 — 검증 산출을 동일 badge 파이프로(멱등)"
      },
      {
        "name": "export",
        "title": "확정 code 노드를 실제 파일 트리로 기록"
      }
    ],
    "skill": {
      "path": "skill/SKILL.md"
    }
  }
}
