{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-workflow",
  "name": "Workflow",
  "version": "0.0.1",
  "description": "\ub4dc\ub798\ud504\ud2b8 \ud30c\uc774\ud504\ub77c\uc778 \u2014 \uc544\uc774\ub514\uc5b4\ub97c LLM \uc800\uc791 \uc6cc\ud06c\ud50c\ub85c\ub85c \uc774\uc288 \ubcf4\ub4dc\uc758 \ub178\ub4dc DAG \uc5d0 \ubc1c\ud589\ud558\uace0, \ucf54\uc5b4 \uc2a4\ucf00\uc904\ub7ec reconcile \ub85c \uc2e4\ud589\u00b7\ucd94\uc801\ud55c\ub2e4. item=exec-one \uac80\uc99d(badge o/x/f), task=exec-stage(generate/hunt/classify/audit \uc2e4\ud589\u00b7\uc790\uc2dd \ubc1c\ud589), blockedBy \uc758\uc874.",
  "entry": "main.js",
  "permissions": [
    "service",
    "sidecar",
    "commands",
    "commands:destructive",
    "schedule",
    "secrets",
    "data",
    "ui",
    "process"
  ],
  "consumes": [
    {
      "id": "soksak-spec-plugin-issue-board",
      "range": "0.0.1"
    },
    {
      "id": "soksak-spec-plugin-prompt-store",
      "range": "0.0.1"
    }
  ],
  "sidecars": [
    {
      "name": "workflow",
      "interface": {
        "id": "soksak-spec-sidecar-workflow",
        "range": "0.0.1"
      }
    }
  ],
  "service": {
    "sidecar": "workflow",
    "interface": {
      "id": "soksak-spec-service",
      "range": "0.0.1"
    },
    "subscribe": [
      "bus:issue-board:changed"
    ]
  },
  "contributes": {
    "commands": [
      {
        "name": "run",
        "title": {
          "ko": "\uc6cc\ud06c\ud50c\ub85c\ub97c \ubc1c\ud589\ud569\ub2c8\ub2e4",
          "en": "Publishes the workflow"
        },
        "bind": "service",
        "description": "Publish a workflow DAG to the issue board from an idea or a pre-authored skeleton. Give `idea` to have the provider author a skeleton (LLM), or `skeleton` (a JSON-serialized workflow-doc) to publish directly with no LLM. Returns the published node summary.",
        "triggers": {
          "ko": "\uc6cc\ud06c\ud50c\ub85c \ubc1c\ud589 \uc2e4\ud589 \uc544\uc774\ub514\uc5b4 \uc2dc\uc791"
        },
        "params": {
          "idea": {
            "type": "string",
            "required": false,
            "description": "Idea text \u2014 the provider authors a skeleton from it (LLM). Mutually exclusive with skeleton; one is required."
          },
          "skeleton": {
            "type": "string",
            "required": false,
            "description": "Pre-authored workflow-doc as a JSON string \u2014 published directly, no LLM. Mutually exclusive with idea."
          },
          "directive": {
            "type": "string",
            "required": false,
            "description": "Override DIRECTIVE for the run; defaults to the skeleton's own or the idea."
          },
          "model": {
            "type": "string",
            "required": false,
            "description": "Provider model for skeleton authoring (idea path only)."
          }
        },
        "returns": "{ ok, published }"
      },
      {
        "name": "ping",
        "title": {
          "ko": "\ud504\ub85c\ubc14\uc774\ub354 \uc0c1\ud0dc\ub97c \uc810\uac80\ud569\ub2c8\ub2e4",
          "en": "Probes the provider"
        },
        "bind": "service",
        "description": "Probe the LLM provider end to end by running one exec-one judgement, confirming auth and reachability. Returns the verdict oxf.",
        "triggers": {
          "ko": "\ud504\ub85c\ubc14\uc774\ub354 \uc810\uac80 \uc0c1\ud0dc \ud655\uc778 \ud5ec\uc2a4"
        },
        "params": {},
        "returns": "{ ok, oxf }"
      },
      {
        "name": "reconcile",
        "title": {
          "ko": "\uc900\ube44\ub41c \uc6cc\ud06c\ud50c\ub85c \ub178\ub4dc\ub97c \uc2e4\ud589\ud569\ub2c8\ub2e4",
          "en": "Runs ready workflow nodes"
        },
        "bind": "service",
        "description": "Advance the DAG one reconcile tick: run every ready node (item=exec-one verify, task=exec-stage), publish children, stamp badges, and poke for the next tick. Idempotent \u2014 a spent tick is a no-op. The reconcile schedule fires this.",
        "triggers": {
          "ko": "\uc2e4\ud589 \uc9c4\ud589 \ud2f1 \uc870\uc815"
        },
        "params": {},
        "returns": "{ ran, published, ... }"
      },
      {
        "name": "research",
        "title": {
          "ko": "\uc870\uc0ac \uc6cc\ud06c\ud50c\ub85c\ub97c \ubc1c\ud589\ud569\ub2c8\ub2e4",
          "en": "Publishes the research workflow"
        },
        "bind": "service",
        "description": "Publish the research workflow for a plan chunk \u2014 gathers evidence (facts) before the plan turn. Requires the chunk to have passed its research gate.",
        "triggers": {
          "ko": "\uc870\uc0ac \ub9ac\uc11c\uce58 \ubc1c\ud589"
        },
        "params": {
          "chunk": {
            "type": "string",
            "required": true,
            "description": "Chunk id to research."
          }
        },
        "returns": "{ ok, published }"
      },
      {
        "name": "issuerize",
        "title": {
          "ko": "\uacc4\ud68d\uc744 \uac1c\ubc1c \uc774\uc288\ub85c \uc2b9\uaca9\ud569\ub2c8\ub2e4",
          "en": "Promotes plans to issues"
        },
        "bind": "service",
        "description": "Promote a confirmed plan chunk into development issues (unlock issues). Requires the chunk's audit to have passed.",
        "triggers": {
          "ko": "\uc774\uc288 \uc2b9\uaca9 \ubc1c\ud589 \uacc4\ud68d"
        },
        "params": {
          "chunk": {
            "type": "string",
            "required": true,
            "description": "Chunk id to promote."
          }
        },
        "returns": "{ ok, issues }"
      },
      {
        "name": "next",
        "title": {
          "ko": "\uac80\uc99d \ub178\ub4dc\uc758 \uc2e4\ud589 \ud328\ud0a4\uc9c0\ub97c \ubc1c\uae09\ud569\ub2c8\ub2e4",
          "en": "Issues a verification work package"
        },
        "bind": "service",
        "description": "Issue the next work package for an external executor (pull v2): the {prompt, schema} for a verification node or an authoring turn, leased so the spawn path skips it. Optionally scoped to a chunk.",
        "triggers": {
          "ko": "\ub2e4\uc74c \ud328\ud0a4\uc9c0 \ubc1c\uae09 \uac80\uc99d"
        },
        "params": {
          "chunk": {
            "type": "string",
            "required": false,
            "description": "Chunk id to scope the package; omit for any ready node."
          }
        },
        "returns": "{ ok, node, prompt, schema } or { ok, idle }"
      },
      {
        "name": "submit",
        "title": {
          "ko": "\uac80\uc99d \ud310\uc815\uc744 \uc81c\ucd9c\ud569\ub2c8\ub2e4",
          "en": "Submits a verification verdict"
        },
        "bind": "service",
        "description": "Submit an external executor's output for a node \u2014 extracted into the same pipe as the spawn path (oxf verdict -> badge/result -> poke). No retry latitude: submission is an explicit act.",
        "triggers": {
          "ko": "\uc81c\ucd9c \ud310\uc815 \uac80\uc99d"
        },
        "params": {
          "node": {
            "type": "string",
            "required": true,
            "description": "Node id being submitted."
          },
          "output": {
            "type": "json",
            "required": true,
            "description": "The executor's output object for that node."
          }
        },
        "returns": "{ ok, badge, ... }"
      },
      {
        "name": "export",
        "title": {
          "ko": "\ud655\uc815 \ucf54\ub4dc\ub97c \ud30c\uc77c\ub85c \ub0b4\ubcf4\ub0c5\ub2c8\ub2e4",
          "en": "Exports confirmed code to files"
        },
        "bind": "service",
        "description": "Write a chunk's confirmed code to files under `dir`. Materializes the ledger and emits each confirmed body to its path.",
        "triggers": {
          "ko": "\ub0b4\ubcf4\ub0b4\uae30 \uc775\uc2a4\ud3ec\ud2b8 \ud30c\uc77c \ud655\uc815"
        },
        "params": {
          "chunk": {
            "type": "string",
            "required": true,
            "description": "Chunk id to export."
          },
          "dir": {
            "type": "string",
            "required": true,
            "description": "Destination directory (absolute) for the written files."
          }
        },
        "returns": "{ ok, written }"
      },
      {
        "name": "entry.add",
        "title": {
          "ko": "\uc774\uc288\ub97c \uc6d0\uc7a5\uc5d0 \ub4f1\ub85d\ud569\ub2c8\ub2e4",
          "en": "Puts an issue on the ledger"
        }
      },
      {
        "name": "lease.acquire",
        "title": {
          "ko": "\uc774\uc288 \ub514\uc2a4\ud328\uce58 \ub9ac\uc2a4\ub97c \ucde8\ub4dd\ud569\ub2c8\ub2e4",
          "en": "Takes the dispatch lease on an issue"
        }
      },
      {
        "name": "lease.renew",
        "title": {
          "ko": "\ubcf4\uc720\ud55c \ub9ac\uc2a4\ub97c \uac31\uc2e0\ud569\ub2c8\ub2e4",
          "en": "Extends a lease you hold"
        }
      },
      {
        "name": "lease.release",
        "title": {
          "ko": "\ubcf4\uc720\ud55c \ub9ac\uc2a4\ub97c \ud574\uc81c\ud569\ub2c8\ub2e4",
          "en": "Releases a lease you hold"
        }
      },
      {
        "name": "lease.list",
        "title": {
          "ko": "\uc6d0\uc7a5 \ud56d\ubaa9\uc744 \uc870\ud68c\ud569\ub2c8\ub2e4",
          "en": "Lists the ledger entries"
        }
      },
      {
        "name": "receipt.add",
        "title": {
          "ko": "\uac80\uc99d \uac00\ub2a5\ud55c \uc99d\uc801\uc744 \uae30\ub85d\ud569\ub2c8\ub2e4",
          "en": "Records verifiable evidence"
        }
      },
      {
        "name": "entry.remove",
        "title": {
          "ko": "\uc6d0\uc7a5 \ud56d\ubaa9\uc744 \uc0ad\uc81c\ud569\ub2c8\ub2e4",
          "en": "Drops a ledger entry"
        },
        "danger": "destructive"
      },
      {
        "name": "board.sync",
        "title": {
          "ko": "\uc6d0\uc7a5\uc744 \uc774\uc288 \ubcf4\ub4dc\uc5d0 \ud22c\uc601\ud569\ub2c8\ub2e4",
          "en": "Projects the ledger onto the issue board"
        }
      },
      {
        "name": "gate.dispatch",
        "title": {
          "ko": "\ub9ac\uc2a4 \ubcf4\uc720\ub97c \ub514\uc2a4\ud328\uce58 \uac8c\uc774\ud2b8\ub85c \uac80\uc0ac\ud569\ub2c8\ub2e4",
          "en": "Gates a dispatch on a live lease"
        }
      },
      {
        "name": "gate.transition",
        "title": {
          "ko": "\uc99d\uc801\uc744 \uc644\ub8cc \uc804\uc774 \uac8c\uc774\ud2b8\ub85c \uac80\uc0ac\ud569\ub2c8\ub2e4",
          "en": "Gates a transition on evidence"
        }
      },
      {
        "name": "drift.check",
        "title": {
          "ko": "\uc6d0\uc7a5\uacfc \uc800\uc7a5\uc18c\uc758 \uc5b4\uae0b\ub0a8\uc744 \ubcf4\uace0\ud569\ub2c8\ub2e4",
          "en": "Reports ledger-vs-repository drift"
        }
      }
    ],
    "schedules": [
      {
        "name": "reconcile",
        "command": "reconcile",
        "trigger": {
          "reconcile": true
        },
        "timeoutMs": 1800000,
        "zombieBackstopMs": 3600000
      }
    ],
    "skill": {
      "path": "skill/SKILL.md"
    },
    "views": [
      {
        "id": "ledger",
        "title": {
          "ko": "\uc6d0\uc7a5",
          "en": "Ledger"
        },
        "icon": "\u25a4",
        "placements": [
          "sidebar-right",
          "content"
        ],
        "defaultPlacement": "content",
        "status": [
          "loading",
          "empty",
          "active",
          "error"
        ]
      }
    ],
    "nodes": [
      {
        "id": "refresh",
        "description": {
          "ko": "\uc0c8\ub85c\uace0\uce68 \ubc84\ud2bc",
          "en": "Refresh button"
        }
      },
      {
        "id": "check",
        "description": {
          "ko": "\ub4dc\ub9ac\ud504\ud2b8 \uac80\uc0ac \ubc84\ud2bc",
          "en": "Drift check button"
        }
      },
      {
        "id": "entry",
        "description": {
          "ko": "\uc6d0\uc7a5 \ud56d\ubaa9 \ud589. data-node=\"entry/<\ud0a4>\"",
          "en": "Ledger entry row. data-node=\"entry/<key>\""
        }
      },
      {
        "id": "drift",
        "description": {
          "ko": "\ub4dc\ub9ac\ud504\ud2b8 \ud589. data-node=\"drift/<\ud0a4>\"",
          "en": "Drift row. data-node=\"drift/<key>\""
        }
      }
    ]
  }
}
